ML_API_KEY=dev-secret-key-change-in-production
ML_BACKEND_URL=http://localhost:8001
ML_BACKEND_API_KEY=dev-backend-key
ML_DEFAULT_SOURCE=example_video.mp4
ML_DEFAULT_CAMERA_ROLE=entry
ML_AUTO_START=false
ML_ALPR_ENGINE=fast-alpr
ML_FASTALPR_DETECTOR_MODEL=yolo-v9-t-384-license-plate-end2end
ML_FASTALPR_DETECTOR_CONF=0.4
ML_FASTALPR_OCR_MODEL=cct-s-v1-global-model
ML_FRAME_SKIP=5
ML_BATCH_SIZE=4
ML_FORCE_RU_OCR=true
ML_MIN_BBOX_AREA_PCT=0.10
ML_TRACKER_WINDOW_SEC=10.0
ML_TRACKER_MIN_CONFIRMATIONS=3
ML_TRACKER_DEPARTURE_SEC=5.0
ML_TRACKER_MAX_TEXT_DISTANCE=1
ML_TRACKER_SPATIAL_MATCH_IOU=0.45
ML_TRACKER_SPATIAL_MATCH_WINDOW_SEC=1.5
ML_TRACKER_MAX_SPATIAL_TEXT_DISTANCE=10
ML_TRACKER_SPATIAL_MATCH_CENTER_DISTANCE_FACTOR=2.5
ML_TRACKER_DUPLICATE_EVENT_IOU=0.35
ML_TRACKER_DUPLICATE_EVENT_WINDOW_SEC=4.0
ML_TRACKER_DUPLICATE_EVENT_TEXT_DISTANCE=2
ML_TRACKER_DUPLICATE_EVENT_CENTER_DISTANCE_FACTOR=3.0
